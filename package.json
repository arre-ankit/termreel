    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/openai": "^3.0.41",
    "@clack/prompts": "^0.9.1",
    "@inquirer/search": "^4.1.4",
    "ai": "^6.0.116",
    "clipboardy": "^4.0.0",
    "commander": "^13.1.0",
    "figlet": "^1.8.0",
    "ora": "^8.2.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@anthropic-ai/sdk",
      "esbuild"
